# Qwen Configuration
QWEN_API_TYPE=ollama
# Get your API key from: https://dashscope.aliyun.com
QWEN_API_KEY=sk-your-api-key-here
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# For local Ollama (if using)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Waza Skills
WAZA_THINK_ENABLED=true
WAZA_WRITE_ENABLED=true
WAZA_DESIGN_ENABLED=true
WAZA_HUNT_ENABLED=true
WAZA_LEARN_ENABLED=true
WAZA_READ_ENABLED=true
WAZA_CHECK_ENABLED=true
WAZA_HEALTH_ENABLED=true

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=sqlite+aiosqlite:///./jarvis.db

# JWT Authentication
# CHANGE THIS IN PRODUCTION!
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# LLM Parameters
TEMPERATURE=0.7
TOP_P=0.9
MAX_TOKENS=2000

# Optional: Web Search API
# SEARCH_API_KEY=your-search-api-key
